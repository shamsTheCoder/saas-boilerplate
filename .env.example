# =============================================================================
# SaaS Boilerplate — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://saas_user:saas_password@localhost:5432/saas_db"
POSTGRES_USER="saas_user"
POSTGRES_PASSWORD="saas_password"
POSTGRES_DB="saas_db"

# --- Redis ---
REDIS_URL="redis://:saas_redis_pass@localhost:6379"
REDIS_PASSWORD="saas_redis_pass"

# --- NestJS API ---
NODE_ENV="development"
API_PORT=3001
API_INTERNAL_URL="http://localhost:3001"   # Used by Next.js Server Actions to reach NestJS

# --- JWT ---
JWT_ACCESS_SECRET="change-me-to-a-long-random-secret-access"
JWT_REFRESH_SECRET="change-me-to-a-long-random-secret-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Next.js ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email (choose one provider) ---
EMAIL_PROVIDER="nodemailer"   # "nodemailer" | "resend"
RESEND_API_KEY=""
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@yoursaas.com"

# --- Storage (choose one provider) ---
STORAGE_PROVIDER="local"   # "local" | "s3"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
LOCAL_UPLOAD_DIR="./uploads"

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
